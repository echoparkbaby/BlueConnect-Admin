# Copy to .env-sign (gitignored) and fill in your values to enable
# Developer ID signing + notarized releases. Without this file, the
# build falls back to ad-hoc signing (local-only).

# --- Required for Developer ID signing ---
# Output of `security find-identity -v -p codesigning`. Format:
#   "Developer ID Application: <Your Name> (<Team ID>)"
SIGN_ID=""

# Your reverse-DNS bundle identifier. Pick a namespace you own.
BUNDLE_ID="com.example.BlueConnectAdmin"

# --- Version (optional; release.sh derives these from the git tag) ---
# CFBundleShortVersionString — user-facing semver.
VERSION="1.0.0"
# CFBundleVersion — monotonic build number; increment per release.
BUILD_NUMBER="1"

# --- Optional: notarization (release.sh) ---
# Keychain profile name created by:
#   xcrun notarytool store-credentials BlueConnectNotary \
#       --apple-id you@example.com \
#       --team-id <YOUR_TEAM_ID> \
#       --password <app-specific-password>
NOTARY_PROFILE=""

# --- Optional: GitHub releases (release.sh) ---
# Format: <owner>/<repo>
GITHUB_REPO=""
