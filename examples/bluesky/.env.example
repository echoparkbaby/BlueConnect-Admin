# BlueSky / BlueConnect deployment env vars. Copy to `.env` (which is
# gitignored by the deploy script) and fill in real values. `docker compose`
# picks `.env` up automatically from the same directory as compose.yml.

# ─── BSC server identity ───────────────────────────────────────────────
# Public hostname the BSC sshd accepts client tunnels on. Mac clients
# use this to phone home. The certs in ./certs/ need to match.
SERVERFQDN=bluesky.example.com

# ─── Database ─────────────────────────────────────────────────────────
# MySQL root password. Used by both the MySQL container itself and BSC's
# PHP to connect. Pick something long; 32+ chars from `openssl rand -hex 16`.
MYSQL_ROOT_PASSWORD=replace-with-strong-password

# ─── Web admin ─────────────────────────────────────────────────────────
# Password for the BSC web admin UI + the same password BlueConnect Admin
# uses when calling the JSON endpoints. Username is hard-coded to `admin`.
WEBADMINPASS=replace-with-different-strong-password

# ─── Outbound email (offline alerts, host state changes) ──────────────
# All four required to send alerts. Skip if you don't want alert emails;
# the BSC web UI still works without them.
EMAILALERT=alerts-go-here@example.com
SMTP_SERVER=smtp.example.com:587
SMTP_AUTH=smtp-username@example.com
SMTP_PASS=smtp-password-or-app-specific-token
