# BlueSky / BlueConnect deployment env vars. Copy to `.env` (which is
# gitignored by the deploy script) and fill in real values. `docker compose`
# picks `.env` up automatically from the same directory as compose.yml.

# ─── BSC server identity ───────────────────────────────────────────────
# Public hostname the BSC sshd accepts client tunnels on. Mac clients
# use this to phone home. The certs in ./certs/ need to match.
SERVERFQDN=bluesky.example.com

# ─── Database ─────────────────────────────────────────────────────────
# MySQL root password. Used by both the MySQL container itself and BSC's
# PHP to connect. Pick something long; 32+ chars from `openssl rand -hex 16`.
MYSQL_ROOT_PASSWORD=replace-with-strong-password

# ─── Web admin ─────────────────────────────────────────────────────────
# Password for the BSC web admin UI on first launch. The BSC container
# reads this ONCE at startup to seed `membership_users.passMD5` for the
# `admin` account. After first boot, you change the admin password via
# the BSC web UI — at which point this env var becomes stale.
WEBADMINPASS=replace-with-different-strong-password

# How the BlueConnect Admin JSON endpoints authenticate HTTP Basic creds:
#
#   env   — Compare against WEBADMINPASS (above). Backward-compatible
#           with older BlueConnect Admin deployments. FOOTGUN: rotating
#           the password via the BSC web UI updates the DB but NOT this
#           env var, so the Mac client will silently keep working with
#           the OLD password and reject the new one until you also edit
#           .env and `docker compose up -d --force-recreate bluesky`.
#
#   db    — Verify against `membership_users.passMD5` directly, same way
#           the BSC web UI itself does. Password rotations through the
#           web UI immediately take effect for the Mac client too — no
#           env edits, no container recreate. RECOMMENDED for new
#           deployments. Note: WEBADMINPASS above must STILL be set
#           because the BSC `run` script refuses to start the container
#           without it; in `db` mode it just becomes a no-op for auth.
#
#   auto  — Default. Picks `db` when WEBADMINPASS is empty/unset, else
#           `env`. In practice you can't actually unset WEBADMINPASS
#           (see note above), so auto mode usually resolves to `env`.
#           Use the explicit `db` setting below to opt in.
#
# RECOMMENDED for new deployments: uncomment the line below.
#WEBADMIN_AUTH=db

# ─── Outbound email (offline alerts, host state changes) ──────────────
# All four required to send alerts. Skip if you don't want alert emails;
# the BSC web UI still works without them.
EMAILALERT=alerts-go-here@example.com
SMTP_SERVER=smtp.example.com:587
SMTP_AUTH=smtp-username@example.com
SMTP_PASS=smtp-password-or-app-specific-token
